{
  "name": "neo",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "packages/*",
    "apps/*",
    "container/agent-runner"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@neo/app",
    "clean": "turbo run clean",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
