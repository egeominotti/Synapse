# ===========================================
# Neo - Claude AI Agent Platform
# ===========================================

# --- Required ---

# OAuth token for Claude CLI
CLAUDE_CODE_OAUTH_TOKEN=

# --- Telegram Bot (required for run.ts) ---

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Admin chat ID for privileged commands (optional)
TELEGRAM_ADMIN_ID=

# --- Agent Settings (optional) ---

# Agent timeout in ms (0 = disabled, max 600000)
# CLAUDE_AGENT_TIMEOUT_MS=0

# Max retries on transient errors (0-10)
# CLAUDE_AGENT_MAX_RETRIES=3

# Initial retry delay in ms (100-30000)
# CLAUDE_AGENT_RETRY_DELAY_MS=1000

# Skip permission prompts (1 = yes, 0 = no)
# CLAUDE_AGENT_SKIP_PERMISSIONS=1

# Max concurrent agents per chat (1-10)
# CLAUDE_AGENT_MAX_CONCURRENT=1

# Custom system prompt
# CLAUDE_AGENT_SYSTEM_PROMPT=

# Path to MCP config JSON
# CLAUDE_AGENT_MCP_CONFIG_PATH=

# --- Database (optional) ---

# SQLite database path (default: ~/.claude-agent/neo.db)
# CLAUDE_AGENT_DB_PATH=

# --- Docker (optional) ---

# Run agents in Docker containers (1 = yes)
# CLAUDE_AGENT_DOCKER=0

# Docker image name
# CLAUDE_AGENT_DOCKER_IMAGE=claude-agent:latest

# --- Voice / STT (optional) ---

# Groq API key for cloud speech-to-text (primary)
GROQ_API_KEY=

# Path to whisper.cpp GGML model (local fallback)
# WHISPER_MODEL_PATH=

# Whisper language code (ISO 639-1 or "auto")
# WHISPER_LANGUAGE=auto

# CPU threads for whisper transcription (1-16)
# WHISPER_THREADS=4
